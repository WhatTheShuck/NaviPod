// views/now_playing.slint

import { Theme, AppTheme } from "../themes/theme.slint";

export component NowPlayingView {
    in property <AppTheme> theme;
    in property <string> track-title: "Unknown Track";
    in property <string> track-artist: "Unknown Artist";
    in property <string> track-album: "Unknown Album";
    in property <float> playback-progress: 0.0;
    in property <bool> is-playing: false;
    in property <image> album-art;
    in property <string> elapsed-time: "0:00";
    in property <string> total-time: "0:00";
    in property <float> volume-level: 0.7;
    in property <bool> shuffle-enabled: false;
    in property <string> repeat-mode: "off";
    in property <string> queue-position: "";

    callback play-pause();
    callback next-track();
    callback prev-track();
    callback menu-pressed();
    callback toggle-shuffle();
    callback cycle-repeat();
    callback scroll-up();
    callback scroll-down();

    width: 100%;
    height: 100%;

    // Classic iPod adds a "Now Playing" header bar at y:0–22, which shifts the
    // rest of the content down. All content elements use y-top as their base offset.
    property <length> y-top: theme == AppTheme.ClassicIPod ? 22px : 0px;

    // ── Background ───────────────────────────────────────────────────────────
    Rectangle {
        width: 100%; height: 100%;
        background: Theme.background;
    }

    // Background scroll area (volume control via scroll wheel)
    TouchArea {
        width: 100%; height: 100%;
        scroll-event(e) => {
            if e.delta-y < 0 { root.scroll-up(); } else { root.scroll-down(); }
            EventResult.accept
        }
    }

    // ── Classic iPod: "Now Playing" header bar ────────────────────────────────
    if theme == AppTheme.ClassicIPod: Rectangle {
        x: 0; y: 0; width: 100%; height: 22px;
        background: Theme.header-bg;
        clip: true;

        Text {
            x: 28px; y: 3px;
            width: parent.width - 56px;
            text: "Now Playing";
            color: Theme.header-text;
            font-size: Theme.font-size-medium;
            font-weight: 700;
            horizontal-alignment: center;
        }

        // Back (‹) button
        Text { x: 4px; y: 3px; text: "‹"; color: Theme.header-text; font-size: Theme.font-size-large; }
        TouchArea {
            x: 0; y: 0; width: 28px; height: 22px;
            clicked => { root.menu-pressed(); }
        }

        // Bottom border
        Rectangle { y: 21px; width: 100%; height: 1px; background: rgba(0, 0, 0, 0.28); }
    }

    // ── LiquidGlass: ambient glow behind album art ────────────────────────────
    if Theme.glass-opacity > 0.0: Rectangle {
        x: 2px; y: y-top + 2px;
        width: 92px; height: 92px;
        border-radius: Theme.radius + 6px;
        background: rgba(100, 210, 255, 0.12);
    }

    // ── Classic: drop-shadow behind album art ────────────────────────────────
    if theme == AppTheme.ClassicIPod: Rectangle {
        x: 10px; y: y-top + 10px;
        width: 80px; height: 80px;
        border-radius: Theme.radius;
        background: rgba(0, 0, 0, 0.22);
    }

    // ── Album art ────────────────────────────────────────────────────────────
    Rectangle {
        x: 8px; y: y-top + 8px;
        width: 80px; height: 80px;
        border-radius: Theme.radius;
        background: Theme.surface;
        border-width: theme == AppTheme.ClassicIPod ? 2px : 1px;
        border-color: theme == AppTheme.ClassicIPod
            ? rgba(0, 0, 0, 0.28)
            : Theme.surface-border;
        clip: true;

        Image {
            width: 100%; height: 100%;
            source: album-art;
            image-fit: cover;
        }
    }

    // LiquidGlass: gradient shimmer overlay on the top portion of the art
    if Theme.glass-opacity > 0.0: Rectangle {
        x: 8px; y: y-top + 8px;
        width: 80px; height: 28px;
        border-radius: Theme.radius;
        background: @linear-gradient(180deg, rgba(255, 255, 255, 0.20), rgba(255, 255, 255, 0.0));
    }

    // ── LiquidGlass: frosted glass card behind track info ────────────────────
    if Theme.glass-opacity > 0.0: Rectangle {
        x: 90px; y: y-top + 4px;
        width: 226px; height: 88px;
        border-radius: 12px;
        background: rgba(255, 255, 255, 0.05);
        border-width: 1px;
        border-color: rgba(255, 255, 255, 0.12);
    }
    // Shimmer edge at top of that card
    if Theme.glass-opacity > 0.0: Rectangle {
        x: 91px; y: y-top + 4px;
        width: 224px; height: 1px;
        background: rgba(255, 255, 255, 0.32);
    }

    // ── Track info ───────────────────────────────────────────────────────────
    Text {
        x: 96px; y: y-top + 10px;
        width: 216px;
        text: track-title;
        color: Theme.text-primary;
        font-size: Theme.font-size-large;
        font-weight: 700;
        overflow: elide;
    }

    Text {
        x: 96px; y: y-top + 28px;
        width: 216px;
        text: track-artist;
        color: Theme.accent;
        font-size: Theme.font-size-medium;
        overflow: elide;
    }

    Text {
        x: 96px; y: y-top + 44px;
        width: 216px;
        text: track-album;
        color: Theme.text-secondary;
        font-size: Theme.font-size-small;
        overflow: elide;
    }

    // Queue position (e.g. "♪ 3 / 10")
    if queue-position != "": Text {
        x: 96px; y: y-top + 58px;
        width: 216px;
        text: "♪ " + queue-position;
        color: Theme.text-secondary;
        font-size: Theme.font-size-small;
    }

    // ── Progress bar ─────────────────────────────────────────────────────────
    Rectangle {
        x: 8px; y: y-top + 100px;
        width: 304px; height: 4px;
        border-radius: 2px;
        background: Theme.progress-track;

        // Filled portion
        Rectangle {
            x: 0; y: 0;
            width: parent.width * playback-progress;
            height: 100%;
            border-radius: 2px;
            background: Theme.progress-fill;
        }

        // LiquidGlass: bright glint on top of the fill
        if Theme.glass-opacity > 0.0: Rectangle {
            x: 0; y: 0;
            width: parent.width * playback-progress;
            height: 2px;
            border-radius: 2px;
            background: rgba(255, 255, 255, 0.35);
        }
    }

    // ── Elapsed / total time ─────────────────────────────────────────────────
    Text {
        x: 8px; y: y-top + 107px;
        width: 60px;
        text: elapsed-time;
        color: Theme.text-secondary;
        font-size: Theme.font-size-small;
        horizontal-alignment: left;
    }
    Text {
        x: 252px; y: y-top + 107px;
        width: 60px;
        text: total-time;
        color: Theme.text-secondary;
        font-size: Theme.font-size-small;
        horizontal-alignment: right;
    }

    // ── Playback controls ────────────────────────────────────────────────────

    // Back (‹) — not shown for Classic since it's in the header bar
    if theme != AppTheme.ClassicIPod: Rectangle {
        x: 8px; y: y-top + 120px; width: 30px; height: 24px;
        border-radius: Theme.control-radius;
        background: Theme.control-bg;
        border-width: 1px; border-color: Theme.control-border;
        Text { x: 0; y: 2px; width: 100%; text: "‹";
               color: Theme.text-secondary; font-size: Theme.font-size-large;
               horizontal-alignment: center; }
        TouchArea { width: 100%; height: 100%; clicked => { root.menu-pressed(); } }
    }

    // Previous
    Rectangle {
        x: 80px; y: y-top + 120px; width: 40px; height: 24px;
        border-radius: Theme.control-radius;
        background: Theme.control-bg;
        border-width: 1px; border-color: Theme.control-border;
        Text { x: 0; y: 2px; width: 100%; text: "⏮";
               color: Theme.text-primary; font-size: 14px; horizontal-alignment: center; }
        TouchArea { width: 100%; height: 100%; clicked => { root.prev-track(); } }
    }

    // Play / Pause
    Rectangle {
        x: 130px; y: y-top + 120px; width: 60px; height: 24px;
        border-radius: Theme.control-radius;
        background: Theme.control-bg;
        border-width: 1px; border-color: Theme.control-border;
        Text { x: 0; y: 2px; width: 100%; text: is-playing ? "⏸" : "▶";
               color: Theme.text-primary; font-size: 14px; horizontal-alignment: center; }
        TouchArea { width: 100%; height: 100%; clicked => { root.play-pause(); } }
    }

    // Next
    Rectangle {
        x: 230px; y: y-top + 120px; width: 40px; height: 24px;
        border-radius: Theme.control-radius;
        background: Theme.control-bg;
        border-width: 1px; border-color: Theme.control-border;
        Text { x: 0; y: 2px; width: 100%; text: "⏭";
               color: Theme.text-primary; font-size: 14px; horizontal-alignment: center; }
        TouchArea { width: 100%; height: 100%; clicked => { root.next-track(); } }
    }

    // ── Volume bar ───────────────────────────────────────────────────────────
    Text {
        x: 8px; y: y-top + 150px;
        width: 26px;
        text: "Vol";
        color: Theme.text-secondary;
        font-size: Theme.font-size-small;
    }
    Rectangle {
        x: 38px; y: y-top + 153px;
        width: 274px; height: 3px;
        border-radius: 1px;
        background: Theme.progress-track;

        Rectangle {
            x: 0; y: 0;
            width: parent.width * volume-level;
            height: 100%;
            border-radius: 1px;
            background: Theme.accent;
        }
    }

    // ── Shuffle / Repeat ─────────────────────────────────────────────────────
    Rectangle {
        x: 8px; y: y-top + 164px; width: 100px; height: 18px;
        Text {
            x: 0; y: 2px; width: 100%;
            text: shuffle-enabled ? "⇌ Shuffle: On" : "⇌ Shuffle";
            color: shuffle-enabled ? Theme.accent : Theme.text-secondary;
            font-size: Theme.font-size-small;
        }
        TouchArea { width: 100%; height: 100%; clicked => { root.toggle-shuffle(); } }
    }

    Rectangle {
        x: 212px; y: y-top + 164px; width: 100px; height: 18px;
        Text {
            x: 0; y: 2px; width: 100%;
            text: repeat-mode == "one" ? "↺ Repeat: 1"
                : repeat-mode == "all" ? "↺ Repeat: ∞"
                : "↺ Repeat";
            color: repeat-mode != "off" ? Theme.accent : Theme.text-secondary;
            font-size: Theme.font-size-small;
            horizontal-alignment: right;
        }
        TouchArea { width: 100%; height: 100%; clicked => { root.cycle-repeat(); } }
    }

    // ── Theme label (dev aid, bottom-right corner) ────────────────────────────
    Text {
        x: 260px; y: 228px;
        width: 56px;
        text: theme == AppTheme.LiquidGlass ? "Glass"
            : theme == AppTheme.Material     ? "Material"
            : "Classic";
        color: Theme.text-secondary;
        font-size: Theme.font-size-small;
        horizontal-alignment: right;
    }
}
